{
  "name": "@super/server",
  "version": "1.1.7",
  "private": true,
  "main": "data/serve/app.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev nodemon --inspect --exec \"pnpm run generate:routes && tsx src/app.ts\"",
    "start": "cross-env NODE_ENV=prod node data/serve/app.js",
    "generate:routes": "tsx scripts/generateRouter.ts",
    "lint": "pnpm run generate:routes && tsc --noEmit",
    "typecheck": "pnpm run generate:routes && tsc --noEmit",
    "build": "cross-env NODE_ENV=prod tsx scripts/build.ts",
    "debug:ai": "npx @ai-sdk/devtools",
    "vendor2json": "node scripts/vendor2json.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:",
    "@ai-sdk/deepseek": "catalog:",
    "@ai-sdk/devtools": "catalog:",
    "@ai-sdk/google": "catalog:",
    "@ai-sdk/openai": "catalog:",
    "@ai-sdk/openai-compatible": "catalog:",
    "@ai-sdk/xai": "catalog:",
    "@huggingface/transformers": "catalog:",
    "@rmp135/sql-ts": "catalog:",
    "ai": "catalog:",
    "axios": "catalog:",
    "axios-retry": "catalog:",
    "bcryptjs": "catalog:",
    "compressing": "catalog:",
    "cors": "catalog:",
    "dotenv": "catalog:",
    "express": "catalog:",
    "express-ws": "catalog:",
    "fast-glob": "catalog:",
    "form-data": "catalog:",
    "graphlib": "catalog:",
    "is-path-inside": "catalog:",
    "js-md5": "catalog:",
    "jsonwebtoken": "catalog:",
    "knex": "catalog:",
    "lodash": "catalog:",
    "morgan": "catalog:",
    "mysql2": "catalog:",
    "p-limit": "catalog:",
    "qwen-ai-provider-v5": "catalog:",
    "serialize-error": "catalog:",
    "sharp": "catalog:",
    "socket.io": "catalog:",
    "sucrase": "catalog:",
    "uuid": "catalog:",
    "vercel-minimax-ai-provider": "catalog:",
    "vm2": "catalog:",
    "zhipu-ai-provider": "catalog:",
    "zod": "catalog:server"
  },
  "devDependencies": {
    "@super/tsconfig": "workspace:*",
    "@types/cors": "catalog:",
    "@types/express": "catalog:",
