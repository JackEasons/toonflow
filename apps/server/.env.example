NODE_ENV=prod
PORT=10588

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=dramastudio
MYSQL_CONNECTION_LIMIT=10
MYSQL_CHARSET=utf8mb4
MYSQL_TIMEZONE=Z
# Keep disabled for normal app users. Enable only when MYSQL_USER has CREATE DATABASE privilege.
MYSQL_AUTO_CREATE_DATABASE=false

# Optional MySQL socket mode. Leave empty when using host/port.
# MYSQL_SOCKET_PATH=
