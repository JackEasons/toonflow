NODE_ENV=prod
PORT=10588

# Database
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=dramastudio
MYSQL_CONNECTION_LIMIT=10
MYSQL_CHARSET=utf8mb4
MYSQL_TIMEZONE=Z
# Keep disabled for normal app users. Enable only when MYSQL_USER has CREATE DATABASE privilege.
MYSQL_AUTO_CREATE_DATABASE=false

# Optional MySQL socket mode. Leave empty when using host/port.
# MYSQL_SOCKET_PATH=

# Generated resource storage. When these are set, /oss files are written to MinIO.
MINIO_ENDPOINT=http://localhost:19000
MINIO_REGION=us-east-1
MINIO_BUCKET=drama-studio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_FORCE_PATH_STYLE=true
