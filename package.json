{
  "name": "super-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo build",
    "build:analyze": "turbo build:analyze",
    "build:app": "turbo run build --filter=@super/web --filter=@super/server --filter=@super/admin",
    "build:server": "pnpm -F @super/server run build",
    "build:web": "pnpm -F @super/web run build",
    "build:admin": "pnpm -F @super/admin run build",
    "build:docker": "./scripts/deploy/build-local-docker-image.sh",
    "changeset": "pnpm exec changeset",
    "check": "pnpm run check:circular && pnpm run check:dep && pnpm run check:type && pnpm check:cspell",
    "check:circular": "vsh check-circular",
    "check:dep": "vsh check-dep",
    "check:type": "turbo run typecheck",
    "clean": "node ./scripts/clean.mjs",
    "commit": "czg",
    "dev": "turbo-run dev",
    "dev:app": "turbo run dev --parallel --filter=@super/server --filter=@super/web --filter=@super/admin",
    "dev:server": "pnpm -F @super/server run dev",
    "dev:web": "pnpm -F @super/web run dev",
    "dev:admin": "pnpm -F @super/admin run dev",
    "format": "vsh lint --format",
    "lint": "vsh lint",
    "lint:admin": "pnpm -F @super/admin run typecheck",
    "lint:server": "pnpm -F @super/server run lint",
    "lint:web": "pnpm -F @super/web run lint",
    "postinstall": "pnpm -r run --if-present stub",
    "preinstall": "npx only-allow pnpm",
    "prepare": "is-ci || pnpm exec lefthook install",
    "preview": "turbo-run preview",
    "publint": "vsh publint",
    "reinstall": "pnpm run clean -- --del-lock && pnpm install",
    "test:unit": "vitest run --dom",
    "test:e2e": "turbo run test:e2e",
    "typecheck:admin": "pnpm -F @super/admin run typecheck",
    "typecheck:server": "pnpm -F @super/server run typecheck",
    "typecheck:web": "pnpm -F @super/web run typecheck",
    "update:deps": "npx taze -r -w",
    "version": "pnpm exec changeset version && pnpm install --no-frozen-lockfile"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@super/commitlint-config": "workspace:*",
    "@super/eslint-config": "workspace:*",
    "@super/oxfmt-config": "workspace:*",
    "@super/oxlint-config": "workspace:*",
    "@super/stylelint-config": "workspace:*",
    "@super/tailwind-config": "workspace:*",
    "@super/tsconfig": "workspace:*",
    "@super/turbo-run": "workspace:*",
    "@super/vite-config": "workspace:*",
    "@super/vsh": "workspace:*",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "cross-env": "catalog:",
    "cspell": "catalog:",
    "eslint": "catalog:",
    "happy-dom": "catalog:",
    "is-ci": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": "^22.18.0 || ^24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.4.0"
}
