    "@super/types": "workspace:*",
    "@super/utils": "workspace:*",
    "@vueuse/core": "catalog:",
    "@vueuse/motion": "catalog:",
    "echarts": "catalog:",
    "vue": "catalog:",
    "vxe-pc-ui": "catalog:",
    "vxe-table": "catalog:"
