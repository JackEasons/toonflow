{
  "name": "@super-core/popup-ui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsdown",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "production": "./src/index.ts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@super-core/composables": "workspace:*",
    "@super-core/icons": "workspace:*",
    "@super-core/preferences": "workspace:*",
    "@super-core/shadcn-ui": "workspace:*",
    "@super-core/shared": "workspace:*",
    "@super-core/typings": "workspace:*",
    "@vueuse/core": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "unplugin-vue": "catalog:"
  }
}
